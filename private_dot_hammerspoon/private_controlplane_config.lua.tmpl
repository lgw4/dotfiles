spoon.ControlPlane.contexts = {
    home = {
        rules = {
            { kind = "ssid",   confidence = 0.5, value = { {{ onepasswordRead "op://Personal/Home Network/ssid" | trim | quote }} } },
            { kind = "bssid",  confidence = 0.5, value = {
{{- range (onepasswordRead "op://Personal/Home Network/bssid" | splitList "\n") }}
                {{ . | trim | quote }},
{{- end }}
            } },
            { kind = "subnet", confidence = 0.5, value = { {{ onepasswordRead "op://Personal/Home Network/subnet" | trim | quote }} } },
        },
    },
    none = { rules = {} },
}

spoon.ControlPlane.threshold = 0.6
spoon.ControlPlane.margin = 0.3

spoon.ControlPlane.onContextChange = function(newName, newCtx, oldName)
    if newName == "home" then
        hs.execute("networksetup -switchtolocation Home")
    else
        hs.execute("networksetup -switchtolocation Automatic")
    end
end

spoon.ControlPlane:start()
