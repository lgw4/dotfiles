#!/usr/bin/env sh

killall Mail 2>/dev/null
sleep 2

mail_dir=""
max_ver=0
for dir in "$HOME/Library/Mail"/V*/; do
  ver=${dir%/}
  ver=${ver##*V}
  if [ "$ver" -gt "$max_ver" ] 2>/dev/null; then
    max_ver=$ver
    mail_dir=${dir%/}
  fi
done

if [ -z "$mail_dir" ]; then
  printf 'Could not find Mail data directory matching V* under: %s\n' "$HOME/Library/Mail/" >&2
  exit 1
fi

index_file="$mail_dir/MailData/Envelope Index"

if [ ! -f "$index_file" ]; then
  printf 'Could not find Envelope Index at: %s\n' "$index_file" >&2
  printf 'Selected Mail data directory: %s\n' "$mail_dir" >&2
  exit 1
fi

size_before=$(ls -sk "$index_file" | awk '{printf "%.2f", $1 / 1024}')

if ! /usr/bin/sqlite3 "$index_file" vacuum; then
  printf 'Failed to vacuum Envelope Index. The database may be locked.\n' >&2
  open -a Mail
  exit 1
fi

size_after=$(ls -sk "$index_file" | awk '{printf "%.2f", $1 / 1024}')

printf 'Mail index before: %s MB\n' "$size_before"
printf 'Mail index after:  %s MB\n' "$size_after"
printf '\nEnjoy the new speed!\n'

open -a Mail
